-- ==================== FUNÇÕES (Mesmas otimizações anteriores) ====================
local function registrarAlvo(humanoid)
	if not humanoid or humanoid.Parent == localPlayer.Character then return end
	local root = humanoid.Parent:FindFirstChild(ALVO_TAG)
	if not root then return end
	table.insert(possiveisAlvos, {root = root, humanoid = humanoid})
end

local function atualizarCache()
	possiveisAlvos = {}
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Humanoid") and obj.Health > 0 and obj.Parent ~= localPlayer.Character then
			registrarAlvo(obj)
		end
	end
end

local function setupCache()
	atualizarCache()
	for _, conn in ipairs(conexoes) do conn:Disconnect() end
	conexoes = {}
	
	table.insert(conexoes, Workspace.DescendantAdded:Connect(function(desc)
		if desc:IsA("Humanoid") then
			task.wait(0.1)
			registrarAlvo(desc)
		end
	end))
end

local function obterNpcMaisProximo()
	local personagemPlayer = localPlayer.Character
	if not personagemPlayer or not personagemPlayer:FindFirstChild("HumanoidRootPart") then return nil end
	
	local posicaoPlayer = personagemPlayer.HumanoidRootPart.Position
	local melhorAlvo = nil
	local menorDistancia = DISTANCIA_MAXIMA

	for _, alvo in ipairs(possiveisAlvos) do
		if alvo.root and alvo.humanoid.Health > 0 then
			local dist = (posicaoPlayer - alvo.root.Position).Magnitude
			if dist < menorDistancia then
				menorDistancia = dist
				melhorAlvo = alvo.root
			end
		end
	end
	return melhorAlvo
end

local function atualizarCamera()
	if not lockOnAtivo or not alvoAtual or not alvoAtual.Parent then return end
	local humanoid = alvoAtual.Parent:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.Health <= 0 then
		lockOnAtivo = false
		if conexaoCamera then conexaoCamera:Disconnect() end
		return
	end
	camera.CFrame = CFrame.new(camera.CFrame.Position, alvoAtual.Position)
end

local function toggleLock()
	if lockOnAtivo then
		lockOnAtivo = false
		alvoAtual = nil
		if conexaoCamera then conexaoCamera:Disconnect() end
		toggleButton.Text = "LIGAR"
		toggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
		mobileLockButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
	else
		local alvo = obterNpcMaisProximo()
		if alvo then
			alvoAtual = alvo
			lockOnAtivo = true
			conexaoCamera = RunService.RenderStepped:Connect(atualizarCamera)
			toggleButton.Text = "DESLIGAR"
			toggleButton.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
			mobileLockButton.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
		else
			warn("Nenhum alvo próximo.")
		end
	end
end

local function mudarTecla()
	if esperandoTecla then return end
	esperandoTecla = true
	changeKeyButton.Text = "Aguardando..."
	
	local conn
	conn = UserInputService.InputBegan:Connect(function(input, gp)
		if gp or input.KeyCode == Enum.KeyCode.Unknown then return end
		TECLA_LOCK = input.KeyCode
		localPlayer:SetAttribute("LockOnKey", TECLA_LOCK.Name)
		keyLabel.Text = "Tecla: " .. TECLA_LOCK.Name
		changeKeyButton.Text = "🔑 Alterar Tecla"
		conn:Disconnect()
		esperandoTecla = false
	end)
end

