-- ==================== FUNÇÃO PARA MOVER BOTÕES ====================
local function makeDraggable(button)
	local dragging = false
	local dragStart, startPos

	button.InputBegan:Connect(function(input)
		if editMode and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
			dragging = true
			dragStart = input.Position
			startPos = button.Position
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			button.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	button.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
end

local function toggleEditMode()
	editMode = not editMode
	if editMode then
		editButton.Text = "🔒 Travar Posições"
		editButton.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
		print("Modo Edição ativado - Arraste os botões")
	else
		editButton.Text = "✏️ Editar Posições"
		editButton.BackgroundColor3 = Color3.fromRGB(100, 60, 180)
		print("Posições travadas!")
	end
end

-- ==================== LÓGICA DO LOCK ====================
local function obterPlayerMaisProximoDaVisao()
	local personagemPlayer = localPlayer.Character
	if not personagemPlayer or not personagemPlayer:FindFirstChild("HumanoidRootPart") then return nil end

	local posicaoCamera = camera.CFrame.Position
	local lookVector = camera.CFrame.LookVector
	local melhorAlvo = nil
	local melhorAngulo = FOV_LOCK

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer and player.Character then
			local root = player.Character:FindFirstChild(ALVO_TAG)
			local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
			if root and humanoid and humanoid.Health > 0 then
				local direction = (root.Position - posicaoCamera).Unit
				local angulo = math.acos(math.clamp(lookVector:Dot(direction), -1, 1)) * (180 / math.pi)
				local distancia = (root.Position - posicaoCamera).Magnitude
				
				if angulo < melhorAngulo and distancia <= DISTANCIA_MAXIMA then
					melhorAngulo = angulo
					melhorAlvo = root
				end
			end
		end
	end
	return melhorAlvo
end

local function atualizarCamera()
	if not lockOnAtivo or not alvoAtual or not alvoAtual.Parent then return end
	local humanoid = alvoAtual.Parent:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.Health <= 0 then
		lockOnAtivo = false
		if conexaoCamera then conexaoCamera:Disconnect() end
		return
	end
	camera.CFrame = CFrame.new(camera.CFrame.Position, alvoAtual.Position)
end

local function toggleLock()
	if lockOnAtivo then
		lockOnAtivo = false
		alvoAtual = nil
		if conexaoCamera then conexaoCamera:Disconnect() end
		toggleButton.Text = "LIGAR"
		toggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
		mobileLockButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
	else
		local alvo = obterPlayerMaisProximoDaVisao()
		if alvo then
			alvoAtual = alvo
			lockOnAtivo = true
			conexaoCamera = RunService.RenderStepped:Connect(atualizarCamera)
			toggleButton.Text = "DESLIGAR"
			toggleButton.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
			mobileLockButton.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
		else
			warn("Nenhum jogador na sua mira.")
		end
	end
end

local function mudarTecla()
	if esperandoTecla then return end
	esperandoTecla = true
	changeKeyButton.Text = "Aguardando..."
	
	local conn
	conn = UserInputService.InputBegan:Connect(function(input, gp)
		if gp or input.KeyCode == Enum.KeyCode.Unknown then return end
		TECLA_LOCK = input.KeyCode
		localPlayer:SetAttribute("LockOnKey", TECLA_LOCK.Name)
		keyLabel.Text = "Tecla: " .. TECLA_LOCK.Name
		changeKeyButton.Text = "🔑 Alterar Tecla"
		conn:Disconnect()
		esperandoTecla = false
	end)
end

